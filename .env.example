# ─── PostgreSQL ───────────────────────────────────────────────────────────────
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=inventory_snap
POSTGRES_USER=inventory
POSTGRES_PASSWORD=changeme

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0

# ─── MinIO ────────────────────────────────────────────────────────────────────
MINIO_ENDPOINT=minio:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=changeme_minio
MINIO_SECURE=false
# Buckets (auto-created on startup)
MINIO_BUCKET_PHOTOS=photos
MINIO_BUCKET_THUMBNAILS=thumbnails
MINIO_BUCKET_DOCUMENTS=documents
MINIO_BUCKET_EXPORTS=exports
MINIO_BUCKET_BACKUPS=backups

# ─── Application Security ─────────────────────────────────────────────────────
# Generate with: openssl rand -hex 32
SECRET_KEY=changeme-generate-with-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=60
JWT_REFRESH_EXPIRE_DAYS=30

# ─── AI Provider ──────────────────────────────────────────────────────────────
# Options: ollama, openai, claude
# Set to "none" to disable AI (manual-only mode)
AI_PROVIDER=ollama
AI_FALLBACK_CHAIN=ollama,openai
AI_CONFIDENCE_THRESHOLD=0.6
AI_MAX_OBJECTS_PER_PHOTO=20

# Ollama (local, default)
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_VISION_MODEL=llava:13b

# OpenAI (optional external)
OPENAI_API_KEY=
OPENAI_VISION_MODEL=gpt-4o

# Anthropic Claude (optional external)
CLAUDE_API_KEY=
CLAUDE_VISION_MODEL=claude-3-5-sonnet-20241022

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:80,http://localhost

# ─── Celery ───────────────────────────────────────────────────────────────────
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ─── Flower (Celery monitoring) ───────────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=changeme_flower

# ─── Application ──────────────────────────────────────────────────────────────
APP_NAME=Inventory Snap
APP_VERSION=0.1.0
DEBUG=false
LOG_LEVEL=INFO
# Base URL used for presigned MinIO URLs returned to clients
PUBLIC_MINIO_URL=http://localhost:9000

# ─── Nginx / TLS ──────────────────────────────────────────────────────────────
DOMAIN=localhost
# Set to true to enable Let's Encrypt (requires valid domain)
LETSENCRYPT_ENABLED=false
